# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# TELEGRAM_BOT_TOKEN: Bot token from @BotFather. Never hardcode in source.
TELEGRAM_BOT_TOKEN=""

# TELEGRAM_WEBHOOK_SECRET: Secret token for verifying incoming webhook requests.
# Set via setWebhook API param `secret_token`. Telegram sends it in
# X-Telegram-Bot-Api-Secret-Token header so the server can verify authenticity.
TELEGRAM_WEBHOOK_SECRET=""

# ALLOWED_HOSTS: Comma-separated list of trusted hostnames for webhook URL construction.
# Prevents SSRF via spoofed Host/X-Forwarded-Host headers.
ALLOWED_HOSTS=""

# ADMIN_PASSCODE_HASH: SHA-256 hex digest of the admin PIN code.
# Generate with: echo -n "YOUR_PIN" | sha256sum
ADMIN_PASSCODE_HASH=""

