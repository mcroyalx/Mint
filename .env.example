# GEMINI_API_KEY: Required for live Gemini AI valuations.
# When unset, the app falls back to a deterministic mock prospectus.
GEMINI_API_KEY=""

# APP_URL: The public URL where this app is hosted.
# Used for self-referential links and the Telegram Mini App launch button.
APP_URL=""

# TELEGRAM_BOT_TOKEN: Token from @BotFather. Required for the Telegram bot
# webhook. When unset, the webhook runs in sandbox mode (no outgoing messages).
TELEGRAM_BOT_TOKEN=""

# TELEGRAM_WEBHOOK_SECRET: Optional shared secret. When set, it is registered
# with Telegram (secret_token) and every incoming webhook request must present a
# matching X-Telegram-Bot-Api-Secret-Token header, otherwise it is rejected.
TELEGRAM_WEBHOOK_SECRET=""
